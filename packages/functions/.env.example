# InternIQ Cloud Functions - Environment Variables
# Copy this file to .env and fill in your actual API keys.
# These variables are required for the Cloud Functions to operate.

# Adzuna API credentials (required for ingestion)
# Obtain from: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# OpenAI API key (required for extraction and scoring)
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
